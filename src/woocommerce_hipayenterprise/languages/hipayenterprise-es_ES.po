#: includes/gateways/local/class-hipay-paypal.php:122
msgid "Shipping address is required for PayPal payment."
msgstr "La dirección de envío es obligatoria para el pago con PayPal."

#: includes/gateways/local/class-hipay-paypal.php:124
msgid "Invalid delivery address. Please check or correct the following fields: "
msgstr "Dirección de entrega no válida. Por favor, revise o corrija los siguientes campos: "

#: includes/gateways/local/class-hipay-paypal.php:125
msgid "Unable to initialize PayPal. Please check your shipping address."
msgstr "No se puede inicializar PayPal. Por favor, verifique su dirección de envío."

#: includes/gateways/local/class-hipay-paypal.php:126
msgid "Postal Code"
msgstr "Código Postal"

#: includes/gateways/local/class-hipay-paypal.php:127
msgid "City"
msgstr "Ciudad"

#: includes/gateways/local/class-hipay-paypal.php:128
msgid "Country"
msgstr "País"

#: includes/gateways/local/class-hipay-paypal.php:129
msgid "Street Address"
msgstr "Dirección"

#: includes/gateways/local/class-hipay-bancomat-pay.php
#: includes/blocks/local/class-hipay-bancomat-pay-block.php
#: includes/frontend/template/bancomat-pay-pending.php
msgid "The payment will need to be validated on your Bancomat Pay application."
msgstr "El pago deberá ser validado en su aplicación Bancomat Pay."

#: assets/js/blocks/local-payments/payment-method.js
#: includes/gateways/local/class-hipay-paypal.php:126
msgid "Please accept the terms and conditions to use PayPal."
msgstr "Por favor, acepta los términos y condiciones para usar PayPal."

#: assets/js/blocks/local-payments/payment-method.js
msgid "Please accept the terms and conditions to use Apple Pay."
msgstr "Por favor, acepta los términos y condiciones para usar Apple Pay."

#: includes/frontend/template/bancomat-pay.php
#: assets/js/blocks/local-payments/payment-method.js
msgid "Please accept the terms and conditions to use Bancomat Pay."
msgstr "Por favor, acepta los términos y condiciones para usar Bancomat Pay."

#: includes/frontend/template/bancomat-pay-pending.php
msgid "Payment pending"
msgstr "Pago pendiente"

#: includes/frontend/template/bancomat-pay-pending.php
msgid "This page will update automatically once the payment is confirmed."
msgstr "Esta página se actualizará automáticamente una vez confirmado el pago."

#: includes/frontend/template/bancomat-pay-pending.php
msgid "Payment confirmed"
msgstr "Pago confirmado"

#: includes/frontend/template/bancomat-pay-pending.php
msgid "Thank you! Order #%s is now being processed."
msgstr "¡Gracias! El pedido n.º%s está siendo procesado."

#: includes/frontend/template/bancomat-pay-pending.php
msgid "Payment failed"
msgstr "Pago fallido"

#: includes/frontend/template/bancomat-pay-pending.php
msgid "Your payment could not be processed. Please try again."
msgstr "Su pago no pudo ser procesado. Por favor, inténtelo de nuevo."

#: assets/js/blocks/local-payments/payment-method.js
msgid "Please enter a valid phone number."
msgstr "Por favor, introduzca un número de teléfono válido."
